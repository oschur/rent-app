    "paths": {
        "/api/apartments": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Получение списка всех квартир с возможностью фильтрации. Доступно для всех аутентифицированных пользователей.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "apartments"
                ],
                "summary": "Получение всех квартир",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Фильтр по стране",
                        "name": "country",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Фильтр по городу",
                        "name": "city",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Минимальная площадь (м²)",
                        "name": "min_area_m2",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Максимальная площадь (м²)",
                        "name": "max_area_m2",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Количество комнат",
                        "name": "rooms",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Этаж",
                        "name": "floor",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "Разрешены ли животные",
                        "name": "pets_allowed",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Минимальная цена",
                        "name": "min_price",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Максимальная цена",
                        "name": "max_price",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/rent-app_internal_domain_apartment.Apartment"
                            }
                        }
                    },
                    "401": {
                        "description": "Требуется аутентификация",
                        "schema": {
                            "$ref": "#/definitions/internal_handler_apartment.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/internal_handler_apartment.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Создание новой квартиры. Доступно только для арендодателей и администраторов. Допустимые status: \"active\", \"archived\", \"blocked\". Допустимые price unit: \"pernight\", \"permonth\". Floor не может быть больше Totatfloors. Если установлен TotalFloors, Floor должен быть установлен, и наоборот. Все численные значения должны быть больше либо равны нулю.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "apartments"
                ],
                "summary": "Создание квартиры",
                "parameters": [
                    {
                        "description": "Данные квартиры",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_handler_apartment.CreateApartmentRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/rent-app_internal_domain_apartment.Apartment"
                        }
                    },
                    "400": {
                        "description": "Неверный запрос",
                        "schema": {
                            "$ref": "#/definitions/internal_handler_apartment.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Требуется аутентификация",
                        "schema": {
                            "$ref": "#/definitions/internal_handler_apartment.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Доступ запрещен",
                        "schema": {
                            "$ref": "#/definitions/internal_handler_apartment.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/internal_handler_apartment.ErrorResponse"
                        }
                    }
                }
            }
        },
